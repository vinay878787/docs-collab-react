MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
PORT=3000
# Exact origin of the deployed frontend (no trailing slash) — used for CORS and
# Socket.io origin allow-listing. Must match the browser's Origin exactly.
FRONTEND_URL=https://docs-collab-react-frontend.vercel.app
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
CSRF_SECRET=your_csrf_secret
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Frontend build-time var: the HTTPS backend origin (no trailing slash).
VITE_DEV_BACKEND_URL=https://docscollab1.duckdns.org
